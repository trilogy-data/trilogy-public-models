[
  {
    "origin": ["*"],
    "method": ["GET", "HEAD", "OPTIONS"],
    "responseHeader": [
      "Range",
      "Content-Type",
      "Content-Length",
      "Content-Range",
      "Content-Encoding",
      "Accept-Ranges",
      "ETag",
      "Last-Modified"
    ],
    "maxAgeSeconds": 3600
  }
]
