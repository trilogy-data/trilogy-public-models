import aircraft as aircraft;
import airport as origin;
import airport as destination;
import carrier as carrier;


key id int; # Unique identifier for the flight
property id.flight_num string; # carrier-assigned flight number as a string (preserves leading zeros); eg "1692". Not unique over time - the same number is reused daily.
property id.flight_time int; # actual airborne time in minutes (wheels-up to wheels-down); 0-1920, avg ~104
property id.flight_date date; # scheduled operation date (local date at the origin airport); always populated, including for cancelled flights; used as the storage partition key
property id.dep_time datetime?; # actual departure timestamp (local wall time at the origin airport); null when BTS did not record an actual departure (e.g. cancelled before push-back)
property id.arr_time datetime?; # actual arrival timestamp (local wall time at the destination airport); null when BTS did not record an actual arrival (e.g. cancelled or diverted without reaching the destination)
property id.dep_delay int; # departure delay in minutes vs scheduled (negative = early departure); ranges -1133 to 1433, avg ~8
property id.arr_delay int; # arrival delay in minutes vs scheduled (negative = early arrival); ranges -80 to 1180, avg ~6
property id.taxi_out int; # taxi-out time in minutes from gate push-back to wheels-up; avg ~15
property id.taxi_in int; # taxi-in time in minutes from wheels-down to gate arrival; avg ~7
property id.distance int; # great-circle distance between origin and destination in statute miles; 21-4243
property id.cancelled enum<string>['Y', 'N']; #capital string flag, Y or N
property id.diverted enum<string>['Y', 'N']; #capital string flag, Y or N


auto count <-count(id);
auto total_distance <-sum(distance);

auto dep_time.month_start <- date_trunc(dep_time, month);
auto flight_year <- year(flight_date);

# Abstract watermark concept: timestamp of the last successful refresh of the
# flight data. Shared across the root watermark datasource and every derived
# aggregate so freshness_by can compare "built at" vs "source current through".
property <*>.data_through datetime;

# Single-row parquet produced by ingest/refresh_flights.py holding the current
# data_through value; aggregate datasources use it as their freshness root.
root datasource flight_watermark (
    data_through:data_through,
)
grain (data_through)
file `https://storage.googleapis.com/trilogy_public_models/duckdb/faa/watermark.parquet`:`gcs://trilogy_public_models/duckdb/faa/watermark.parquet`;

